{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "ethers": [
        "./node_modules/ethers/lib.esm/index.d.ts"
      ],
      "ethers/*": [
        "./node_modules/ethers/lib.esm/*"
      ]
    },
    "outDir": "./dist",
    "declaration": true,
    "declarationDir": "./dist",
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*",
    "tests/chains.test.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/connectors/worker",
    "src/connectors/workflows",
    "src/connectors/container",
    "src/connectors/catalog",
    "src/connectors/compiler",
    "src/connectors/schema"
  ]
}
