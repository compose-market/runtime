{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "ethers": [
        "./node_modules/ethers/lib.esm/index.d.ts"
      ],
      "ethers/*": [
        "./node_modules/ethers/lib.esm/*"
      ]
    },
    "outDir": "./dist",
    "declaration": true,
    "declarationDir": "./dist",
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
