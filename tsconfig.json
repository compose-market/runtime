{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "baseUrl": ".",
        "paths": {
            "ethers": [
                "./node_modules/ethers/lib.esm/index.d.ts"
            ],
            "ethers/*": [
                "./node_modules/ethers/lib.esm/*"
            ]
        },
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "declaration": true,
        "declarationDir": "./dist",
        "resolveJsonModule": true
    },
    "include": [
        "src/**/*",
        "tests"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
