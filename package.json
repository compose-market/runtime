    "@langchain/openai": "^1.4.5",
    "@libp2p/crypto": "^5.1.17",
    "@libp2p/peer-id": "^6.0.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@temporalio/activity": "^1.17.0",
